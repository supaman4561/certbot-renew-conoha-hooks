# ConoHa API 認証情報
# このファイルを config.env としてコピーして設定してください
# cp config.env.example config.env

# テナントID (ConoHaコントロールパネル > API > テナントID)
CONOHA_TENANT_ID=your_tenant_id

# APIユーザー名とパスワード (ConoHaコントロールパネル > API > APIユーザー)
CONOHA_API_USERNAME=your_api_username
CONOHA_API_PASSWORD=your_api_password

# リージョン
# c3j1: 東京 (VPS for Windows / 新世代), tyo1: 東京, tyo2: 東京2, sin1: シンガポール, sjc1: アメリカ
# コントロールパネル > API のエンドポイントURLで確認できます
CONOHA_REGION=c3j1

# Identity API バージョン
# c3j1 など新世代リージョンは v3, tyo1/tyo2 など旧リージョンは v2.0
CONOHA_IDENTITY_VERSION=v3

# DNS伝播待ち時間（秒）- デフォルト: 60
# ConoHa DNSの反映は通常60秒以内に完了します
CONOHA_PROPAGATION_WAIT=60
